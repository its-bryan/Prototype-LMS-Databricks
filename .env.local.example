APP_ENV=local
APP_TIER=local

# Local Postgres option A — Neon (recommended for Mac, no local install needed)
# Create a free project at https://neon.tech, name the database "lms_leo"
# Copy Connection Details from the Neon dashboard and fill in below:
# PGHOST=<project-id>.us-east-2.aws.neon.tech
# PGPORT=5432
# PGDATABASE=lms_leo
# PGUSER=<neon-username>
# PGPASSWORD=<neon-password>
# PGSSLMODE=require

# Local Postgres option B — local install (original Windows default)
PGHOST=localhost
PGPORT=5432
PGDATABASE=lms_leo
PGUSER=postgres
PGPASSWORD=postgres

LEO_JWT_SECRET=leo-local-dev-secret
HLES_LANDING_VOLUME_PATH=./local-uploads/hles
TRANSLOG_LANDING_VOLUME_PATH=./local-uploads/translog
VITE_USE_LIVE_API=true
