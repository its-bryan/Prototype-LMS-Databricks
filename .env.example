# Resend (for Edge Functions send-email)
# RESEND_API_KEY=re_xxx

# Twilio (for Edge Functions send-sms, initiate-call)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# Supabase - Get these from your project dashboard: https://supabase.com/dashboard/project/_/settings/api
# Use the Legacy API Keys tab → anon key (JWT, starts with eyJ) for reliable auth/login
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (server/scripts only - NEVER expose to client)
# Required for scripts/seed-demo-users.mjs
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Set to "true" to use Supabase (data persists in database across logout/restart)
# When false, enrichment persists in localStorage
VITE_USE_SUPABASE=false

# Lakebase Postgres (Databricks) — for FastAPI backend and for running psql from CLI/agent
# Format: postgresql://user%40domain:<OAUTH_TOKEN>@host/databricks_postgres?sslmode=require
# See docs/DATABRICKS-DATABASE-SETUP.md for host and how to get a token.
# DATABASE_URL=postgresql://nh136948%40hertz.net:<OAUTH_TOKEN>@ep-jolly-cherry-d2k7zib8.database.us-east-1.cloud.databricks.com/databricks_postgres?sslmode=require
