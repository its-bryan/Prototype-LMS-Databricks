# Resend (for Edge Functions send-email)
# RESEND_API_KEY=re_xxx

# Twilio (for Edge Functions send-sms, initiate-call)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# Frontend toggle (Vite)
# Set to "false" to use embedded mock data (no backend required).
# Default should stay true for full-stack testing.
VITE_USE_LIVE_API=true

# JWT secret for FastAPI auth token signing (optional in local dev)
# LEO_JWT_SECRET=leo-mvp-secret-change-in-prod

# Lakebase Postgres host for local FastAPI runs (required locally).
# In Databricks Apps this is injected by the Database resource.
PGHOST=ep-jolly-cherry-d2k7zib8.database.us-east-1.cloud.databricks.com

# Lakebase Postgres (Databricks) — for FastAPI backend and for running psql from CLI/agent
# Format: postgresql://user%40domain:<OAUTH_TOKEN>@host/databricks_postgres?sslmode=require
# See docs/DATABRICKS-DATABASE-SETUP.md for host and how to get a token.
# Optional for scripts/CLI; db.py uses PGHOST + Databricks OAuth token directly.
# DATABASE_URL=postgresql://nh136948%40hertz.net:<OAUTH_TOKEN>@ep-jolly-cherry-d2k7zib8.database.us-east-1.cloud.databricks.com/databricks_postgres?sslmode=require
