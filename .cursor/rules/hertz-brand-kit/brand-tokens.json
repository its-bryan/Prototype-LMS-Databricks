{
  "$schema": "hertz-brand-tokens",
  "$version": "1.0.0",
  "$description": "Hertz Australia brand tokens extracted from hertz.com.au, Mustard Creative case study, Ignition Design System, and brand reference materials.",

  "color": {
    "primary": {
      "primary": {
        "$value": "#FFD100",
        "$description": "Hertz signature gold. THE defining brand color. Use as accent, not background flood."
      },
      "black": {
        "$value": "#272425",
        "$description": "Hertz 'shiny black'. Warmer than pure #000. Primary text, headers, nav backgrounds."
      },
      "white": {
        "$value": "#FFFFFF",
        "$description": "Clean white for backgrounds and contrast surfaces."
      }
    },
    "secondary": {
      "primary-hover": {
        "$value": "#E6BC00",
        "$description": "Darker gold for hover states on primary elements."
      },
      "primary-light": {
        "$value": "#FFE566",
        "$description": "Lighter gold tint for subtle highlights or badges."
      },
      "gold": {
        "$value": "#C9A94E",
        "$description": "Gold Plus Rewards tier. Premium/loyalty accent."
      }
    },
    "neutral": {
      "900": { "$value": "#1A1A1A", "$description": "Near-black for dense text blocks" },
      "800": { "$value": "#333333", "$description": "Body text color" },
      "700": { "$value": "#4A4A4A", "$description": "Secondary text" },
      "600": { "$value": "#666666", "$description": "Placeholder text, captions" },
      "500": { "$value": "#888888", "$description": "Disabled text, muted elements" },
      "400": { "$value": "#AAAAAA", "$description": "Borders, dividers" },
      "300": { "$value": "#CCCCCC", "$description": "Light borders" },
      "200": { "$value": "#E5E5E5", "$description": "Subtle dividers, input borders" },
      "100": { "$value": "#F2F2F2", "$description": "Background tint, alternating rows" },
      "50":  { "$value": "#F8F8F8", "$description": "Page background, card backgrounds" }
    },
    "semantic": {
      "success": { "$value": "#2E7D32", "$description": "Confirmation, availability" },
      "error": { "$value": "#C62828", "$description": "Validation errors, alerts" },
      "warning": { "$value": "#F57F17", "$description": "Caution states — keep distinct from brand gold" },
      "info": { "$value": "#1565C0", "$description": "Informational callouts, links" }
    }
  },

  "typography": {
    "$note": "Hertz historically uses a customized Interstate typeface (with a distinctive low H crossbar) for brand/print and Gotham Condensed for secondary display. For digital UI, specify the closest available web fonts below.",

    "font-family": {
      "display": {
        "$value": "'DM Sans', 'Figtree', 'Inter', system-ui, sans-serif",
        "$description": "Headlines, hero text. DM Sans provides the geometric-grotesque feel closest to Hertz's brand typeface. If you have a Gotham or Interstate license, use those instead."
      },
      "body": {
        "$value": "'Inter', 'DM Sans', system-ui, -apple-system, sans-serif",
        "$description": "Body copy, UI labels, form elements."
      },
      "mono": {
        "$value": "'JetBrains Mono', 'Fira Code', monospace",
        "$description": "Confirmation codes, booking references, technical data."
      }
    },

    "font-size": {
      "xs":    { "$value": "0.75rem",  "$px": "12px", "$description": "Fine print, legal disclaimers" },
      "sm":    { "$value": "0.875rem", "$px": "14px", "$description": "Captions, helper text" },
      "base":  { "$value": "1rem",     "$px": "16px", "$description": "Body text" },
      "lg":    { "$value": "1.125rem", "$px": "18px", "$description": "Lead paragraphs, card titles" },
      "xl":    { "$value": "1.25rem",  "$px": "20px", "$description": "Section headings" },
      "2xl":   { "$value": "1.5rem",   "$px": "24px", "$description": "Page headings" },
      "3xl":   { "$value": "1.875rem", "$px": "30px", "$description": "Major section titles" },
      "4xl":   { "$value": "2.25rem",  "$px": "36px", "$description": "Hero subheadings" },
      "5xl":   { "$value": "3rem",     "$px": "48px", "$description": "Hero headlines" },
      "6xl":   { "$value": "3.75rem",  "$px": "60px", "$description": "Marketing splash / oversized display" }
    },

    "font-weight": {
      "regular":   { "$value": "400" },
      "medium":    { "$value": "500" },
      "semibold":  { "$value": "600" },
      "bold":      { "$value": "700" },
      "extrabold": { "$value": "800", "$description": "Hero text, CTAs — Hertz brand leans bold and confident" }
    },

    "line-height": {
      "tight":  { "$value": "1.15", "$description": "Headlines, display text" },
      "snug":   { "$value": "1.3",  "$description": "Card titles, short text blocks" },
      "normal": { "$value": "1.5",  "$description": "Body copy" },
      "relaxed":{ "$value": "1.65", "$description": "Long-form reading" }
    },

    "letter-spacing": {
      "tight":    { "$value": "-0.025em", "$description": "Large headlines" },
      "normal":   { "$value": "0em" },
      "wide":     { "$value": "0.025em",  "$description": "Buttons, labels" },
      "wider":    { "$value": "0.05em",   "$description": "ALL-CAPS UI labels" },
      "widest":   { "$value": "0.1em",    "$description": "Overline text, category labels" }
    }
  },

  "spacing": {
    "$base": "4px",
    "$note": "4px base grid. All spacing is a multiple of 4.",
    "0":  "0px",
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },

  "border-radius": {
    "none": "0px",
    "sm":   "4px",
    "md":   "6px",
    "lg":   "8px",
    "xl":   "12px",
    "2xl":  "16px",
    "full": "9999px",
    "$note": "Hertz uses TIGHT radii — not rounded pill shapes. Default to 'md' (6px) for cards and buttons. The brand feels automotive and precise, not soft/bubbly."
  },

  "shadow": {
    "sm":   "0 1px 2px rgba(39, 36, 37, 0.06)",
    "md":   "0 2px 8px rgba(39, 36, 37, 0.08)",
    "lg":   "0 4px 16px rgba(39, 36, 37, 0.10)",
    "xl":   "0 8px 32px rgba(39, 36, 37, 0.12)",
    "$note": "Shadows use the brand black (272425) as base, not pure black. Keeps shadows warm."
  },

  "transition": {
    "fast":    "150ms cubic-bezier(0.4, 0, 0.2, 1)",
    "normal":  "250ms cubic-bezier(0.4, 0, 0.2, 1)",
    "slow":    "400ms cubic-bezier(0.4, 0, 0.2, 1)",
    "$note": "Smooth but efficient. Not bouncy or playful — automotive precision."
  },

  "breakpoint": {
    "sm":  "640px",
    "md":  "768px",
    "lg":  "1024px",
    "xl":  "1280px",
    "2xl": "1440px"
  },

  "container": {
    "max-width": "1280px",
    "padding": "16px",
    "padding-lg": "32px"
  }
}
