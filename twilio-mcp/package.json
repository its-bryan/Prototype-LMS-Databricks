{
  "name": "twilio-mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing Twilio SMS, Voice, and account APIs to AI assistants",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "twilio-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "tsx src/http-server.ts",
    "dev": "tsx watch src/index.ts"
  },
  "keywords": ["mcp", "twilio", "sms", "voice"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "twilio": "^5.6.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
